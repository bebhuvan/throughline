---
interface Props {
  label?: string;
}
const { label = 'In context' } = Astro.props;
---
<aside class="my-14 max-w-[28rem] ml-auto mr-0 reveal">
  <div class="flex items-center gap-3 mb-4">
    <span class="block flex-1 h-px bg-rule"></span>
    <span class="font-sans text-[0.625rem] font-bold tracking-[0.14em] uppercase text-accent/60 shrink-0">{label}</span>
    <span class="block flex-1 h-px bg-rule"></span>
  </div>
  <div class="px-5 py-5 bg-paper-warm/50 rounded-sm">
    <p class="font-serif text-[0.9375rem] leading-[1.75] text-ink-secondary [&>strong]:font-semibold [&>strong]:text-ink">
      <slot />
    </p>
  </div>
</aside>

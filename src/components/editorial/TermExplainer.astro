---
interface Props {
  term: string;
}

const { term } = Astro.props;
---

<span class="term-explainer group relative inline" tabindex="0" role="term" aria-describedby:list={[`term-${term.toLowerCase().replace(/\s+/g, '-')}`]}>
  <span class="border-b border-dotted border-accent/40 cursor-help">{term}</span>
  <span id={`term-${term.toLowerCase().replace(/\s+/g, '-')}`} role="tooltip" class="term-tooltip invisible group-hover:visible group-focus-within:visible absolute left-1/2 -translate-x-1/2 bottom-full mb-2 w-64 px-4 py-3 bg-paper-alt text-ink rounded-md shadow-xl text-left z-50 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-200 border border-rule-light">
    <span class="block font-sans text-[0.5625rem] font-bold tracking-[0.1em] uppercase text-accent mb-1">{term}</span>
    <span class="block font-sans text-[0.75rem] font-normal leading-relaxed text-ink-secondary"><slot /></span>
    <span class="absolute left-1/2 -translate-x-1/2 top-full w-2 h-2 bg-paper-alt rotate-45 -mt-1 border-r border-b border-rule-light"></span>
  </span>
</span>

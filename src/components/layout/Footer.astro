---
const year = new Date().getFullYear();
---

<footer class="bg-paper-alt border-t border-rule-light">
  <div class="max-w-[var(--measure-wide)] mx-auto px-6">
    <div class="py-16">
      <!-- Top row: brand + nav -->
      <div class="flex flex-col md:flex-row items-start justify-between gap-12">
        <!-- Brand -->
        <div>
          <a href="/" class="flex items-center gap-3 group mb-4">
            <div class="w-5 h-5 border border-rule rounded-sm flex items-center justify-center group-hover:border-accent/30 transition-colors">
              <span class="block w-2 h-[1.5px] bg-accent"></span>
            </div>
            <span class="font-sans text-[0.5625rem] font-bold tracking-[0.2em] uppercase text-ink-faint group-hover:text-ink-tertiary transition-colors">Throughline</span>
          </a>
          <p class="font-serif text-[0.8125rem] font-light text-ink-faint max-w-xs leading-relaxed">
            Tracing the consequences that reach your daily life.
          </p>
        </div>

        <!-- Nav links -->
        <nav aria-label="Footer navigation" class="flex gap-x-10 gap-y-4 flex-wrap">
          <div class="flex flex-col gap-3">
            <span class="font-sans text-[0.5625rem] font-bold tracking-[0.18em] uppercase text-ink-faint">Browse</span>
            <a href="/archive" class="font-sans text-[0.8125rem] text-ink-tertiary hover:text-accent transition-colors">Archive</a>
            <a href="/about" class="font-sans text-[0.8125rem] text-ink-tertiary hover:text-accent transition-colors">About</a>
          </div>
          <div class="flex flex-col gap-3">
            <span class="font-sans text-[0.5625rem] font-bold tracking-[0.18em] uppercase text-ink-faint">Subscribe</span>
            <a href="/feed.xml" class="font-sans text-[0.8125rem] text-ink-tertiary hover:text-accent transition-colors flex items-center gap-1.5">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 11a9 9 0 0 1 9 9" /><path d="M4 4a16 16 0 0 1 16 16" /><circle cx="5" cy="19" r="1" />
              </svg>
              RSS Feed
            </a>
          </div>
        </nav>
      </div>

      <!-- License + copyright -->
      <div class="mt-12 pt-6 border-t border-rule-light flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <span class="font-mono text-[0.5625rem] text-ink-faint/50">&copy; {year}</span>
          <span class="text-ink-faint/30">&middot;</span>
          <a href="https://creativecommons.org/licenses/by/4.0/" rel="license noopener noreferrer" target="_blank" class="font-sans text-[0.5625rem] text-ink-faint/50 hover:text-ink-tertiary transition-colors flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="10.5" stroke="currentColor" stroke-width="1.5"/>
              <text x="12" y="16" text-anchor="middle" font-size="12" font-weight="700" fill="currentColor" font-family="sans-serif">C</text>
            </svg>
            CC BY 4.0
          </a>
        </div>
        <span class="font-sans text-[0.5625rem] text-ink-faint/40 tracking-wide">Content licensed for sharing with attribution.</span>
      </div>
    </div>
  </div>
</footer>

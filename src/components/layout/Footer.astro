---
const year = new Date().getFullYear();
---

<footer class="bg-paper-alt border-t border-rule-light">
  <div class="max-w-[var(--measure-wide)] mx-auto px-6">
    <div class="py-16">
      <!-- Top row: brand + nav -->
      <div class="flex flex-col md:flex-row items-start justify-between gap-12">
        <!-- Brand -->
        <div>
          <a href="/" class="flex items-center gap-3 group mb-4">
            <div class="w-5 h-5 border border-rule rounded-sm flex items-center justify-center group-hover:border-accent/30 transition-colors">
              <span class="block w-2 h-[1.5px] bg-accent"></span>
            </div>
            <span class="font-sans text-[0.5625rem] font-bold tracking-[0.2em] uppercase text-ink-faint group-hover:text-ink-tertiary transition-colors">Throughline</span>
          </a>
          <p class="font-serif text-[0.8125rem] font-light text-ink-faint max-w-xs leading-relaxed">
            Tracing the consequences that reach your daily life.
          </p>
        </div>

        <!-- Nav links -->
        <nav aria-label="Footer navigation" class="flex gap-x-10 gap-y-4 flex-wrap">
          <div class="flex flex-col gap-3">
            <span class="font-sans text-[0.5625rem] font-bold tracking-[0.18em] uppercase text-ink-faint">Browse</span>
            <a href="/archive" class="font-sans text-[0.8125rem] text-ink-tertiary hover:text-accent transition-colors">Archive</a>
            <a href="/about" class="font-sans text-[0.8125rem] text-ink-tertiary hover:text-accent transition-colors">About</a>
          </div>
          <div class="flex flex-col gap-3">
            <span class="font-sans text-[0.5625rem] font-bold tracking-[0.18em] uppercase text-ink-faint">Connect</span>
            <a href="/feed.xml" class="font-sans text-[0.8125rem] text-ink-tertiary hover:text-accent transition-colors flex items-center gap-1.5">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 11a9 9 0 0 1 9 9" /><path d="M4 4a16 16 0 0 1 16 16" /><circle cx="5" cy="19" r="1" />
              </svg>
              RSS Feed
            </a>
            <a href="https://github.com/bebhuvan/throughline" target="_blank" rel="noopener noreferrer" class="font-sans text-[0.8125rem] text-ink-tertiary hover:text-accent transition-colors flex items-center gap-1.5">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              Source Code
            </a>
          </div>
        </nav>
      </div>

      <!-- License + copyright -->
      <div class="mt-12 pt-6 border-t border-rule-light flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="font-mono text-[0.75rem] text-ink-faint/60">&copy; {year}</span>
          <span class="text-ink-faint/30">&middot;</span>
          <a href="https://creativecommons.org/licenses/by/4.0/" rel="license noopener noreferrer" target="_blank" class="font-sans text-[0.75rem] text-ink-faint/60 hover:text-ink-tertiary transition-colors flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="10.5" stroke="currentColor" stroke-width="1.5"/>
              <text x="12" y="16" text-anchor="middle" font-size="12" font-weight="700" fill="currentColor" font-family="sans-serif">C</text>
            </svg>
            CC BY 4.0
          </a>
        </div>
        <span class="font-sans text-[0.75rem] text-ink-faint/50">Content licensed for sharing with attribution.</span>
      </div>
    </div>
  </div>
</footer>
